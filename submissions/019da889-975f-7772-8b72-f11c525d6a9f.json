{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "green_openai_api_key": {
        "type": "string"
      }
    },
    "required": [
      "green_openai_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.3/amber-manifest.json5",
      "config": {
        "assessment_config": {},
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {}
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/browsecomp-plus/refs/heads/main/amber-manifest.json5",
      "config": {
        "openai_api_key": "${config.green_openai_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/browsecomp-plus-dummy-purple/refs/heads/main/amber-manifest.json5",
      "config": {}
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true
    },
    {
      "to": "#agent.proxy",
      "from": "#gateway.proxy",
      "weak": true
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019da86f-7f5f-7591-a7d2-269de83bda3d",
      "agent": "019da870-41db-7422-8471-1c62f7de23c6"
    }
  }
}